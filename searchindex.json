{"doc_urls":["introduction.html#引言-introduction","introduction.html#如何使用本指南-how-to-use-this-guide","introduction.html#参与贡献-contributing","understanding/what-is-long-covid.html#什么是长新冠","understanding/what-is-long-covid.html#主要特征","understanding/what-is-long-covid.html#官方定义","understanding/what-is-long-covid.html#可能的发病机制","understanding/symptoms.html#常见症状","understanding/symptoms.html#神经系统与认知","understanding/symptoms.html#心血管与自主神经","understanding/symptoms.html#呼吸系统","understanding/symptoms.html#能量与疲劳","understanding/symptoms.html#其他常见症状","understanding/who-is-affected.html#受影响人群","understanding/who-is-affected.html#患病率","understanding/who-is-affected.html#风险因素","understanding/who-is-affected.html#对日常生活的影响","management/pacing.html#节奏调整与能量管理","management/pacing.html#什么是节奏调整","management/pacing.html#能量信封-the-energy-envelope","management/pacing.html#心率监测","management/pacing.html#实用建议","management/pacing.html#3p-原则","management/treatments.html#医疗方案","management/treatments.html#正在研究中的疗法","management/treatments.html#专科转诊","management/treatments.html#临床试验","management/treatments.html#记录您的症状","management/mental-health.html#心理健康","management/mental-health.html#常见的心理健康挑战","management/mental-health.html#寻求支持","management/mental-health.html#自我照顾策略","management/mental-health.html#关于认知行为疗法-cbt-的说明","resources/research.html#科研与研究","resources/research.html#里程碑式研究","resources/research.html#关键发现","resources/research.html#预印本平台与期刊","resources/research.html#正在进行的试验","resources/support.html#支持团体","resources/support.html#在线社区","resources/support.html#患者组织","resources/support.html#寻找当地支持","resources/links.html#常用链接","resources/links.html#官方卫生组织","resources/links.html#患者资源","resources/links.html#工具与应用","resources/links.html#延伸阅读"],"index":{"documentStore":{"docInfo":{"0":{"body":36,"breadcrumbs":1,"title":1},"1":{"body":6,"breadcrumbs":2,"title":2},"10":{"body":0,"breadcrumbs":0,"title":0},"11":{"body":1,"breadcrumbs":0,"title":0},"12":{"body":5,"breadcrumbs":0,"title":0},"13":{"body":4,"breadcrumbs":0,"title":0},"14":{"body":3,"breadcrumbs":0,"title":0},"15":{"body":2,"breadcrumbs":0,"title":0},"16":{"body":0,"breadcrumbs":0,"title":0},"17":{"body":3,"breadcrumbs":0,"title":0},"18":{"body":0,"breadcrumbs":0,"title":0},"19":{"body":0,"breadcrumbs":2,"title":2},"2":{"body":1,"breadcrumbs":1,"title":1},"20":{"body":7,"breadcrumbs":0,"title":0},"21":{"body":0,"breadcrumbs":0,"title":0},"22":{"body":5,"breadcrumbs":1,"title":1},"23":{"body":1,"breadcrumbs":0,"title":0},"24":{"body":6,"breadcrumbs":0,"title":0},"25":{"body":1,"breadcrumbs":0,"title":0},"26":{"body":3,"breadcrumbs":0,"title":0},"27":{"body":0,"breadcrumbs":0,"title":0},"28":{"body":1,"breadcrumbs":0,"title":0},"29":{"body":2,"breadcrumbs":0,"title":0},"3":{"body":4,"breadcrumbs":0,"title":0},"30":{"body":0,"breadcrumbs":0,"title":0},"31":{"body":1,"breadcrumbs":0,"title":0},"32":{"body":1,"breadcrumbs":1,"title":1},"33":{"body":2,"breadcrumbs":0,"title":0},"34":{"body":8,"breadcrumbs":0,"title":0},"35":{"body":1,"breadcrumbs":0,"title":0},"36":{"body":5,"breadcrumbs":0,"title":0},"37":{"body":1,"breadcrumbs":0,"title":0},"38":{"body":2,"breadcrumbs":0,"title":0},"39":{"body":13,"breadcrumbs":0,"title":0},"4":{"body":0,"breadcrumbs":0,"title":0},"40":{"body":10,"breadcrumbs":0,"title":0},"41":{"body":1,"breadcrumbs":0,"title":0},"42":{"body":0,"breadcrumbs":0,"title":0},"43":{"body":3,"breadcrumbs":0,"title":0},"44":{"body":8,"breadcrumbs":0,"title":0},"45":{"body":5,"breadcrumbs":0,"title":0},"46":{"body":3,"breadcrumbs":0,"title":0},"5":{"body":7,"breadcrumbs":0,"title":0},"6":{"body":1,"breadcrumbs":0,"title":0},"7":{"body":3,"breadcrumbs":0,"title":0},"8":{"body":0,"breadcrumbs":0,"title":0},"9":{"body":1,"breadcrumbs":0,"title":0}},"docs":{"0":{"body":"本指南旨在为长新冠 (Long COVID) 患者、其护理人员以及任何希望深入了解该病症的人士提供资源。 长新冠（也称为新冠后遗症或 PASC）影响着全球数百万人。本网站致力于将实用信息、循证资源和社区支持汇集于一处。 This guide is a resource for people living with Long COVID, their caregivers, and anyone who wants to learn more about the condition. Long COVID (also called Post-COVID Conditions or PASC) affects millions of people worldwide. This site aims to gather practical information, evidence-based resources, and community support in one place.","breadcrumbs":"引言 » 引言 (Introduction)","id":"0","title":"引言 (Introduction)"},"1":{"body":"请使用侧边栏在各章节之间进行切换： 了解长新冠 (Understanding Long COVID) — 什么是长新冠、常见症状以及受影响人群。 管理与治疗 (Management & Treatment) — 实用策略和医疗方案。 资源 (Resources) — 研究链接、支持团体和实用工具。","breadcrumbs":"引言 » 如何使用本指南 (How to Use This Guide)","id":"1","title":"如何使用本指南 (How to Use This Guide)"},"10":{"body":"气短或呼吸困难 持续性咳嗽","breadcrumbs":"常见症状 » 呼吸系统","id":"10","title":"呼吸系统"},"11":{"body":"休息无法缓解的重度疲劳 劳累后不适 (PEM) —— 在进行体力或脑力活动后症状加重","breadcrumbs":"常见症状 » 能量与疲劳","id":"11","title":"能量与疲劳"},"12":{"body":"关节或肌肉疼痛 胃肠道问题 味觉或嗅觉改变 焦虑和抑郁 注意： 劳累后不适 (Post-exertional malaise (PEM)) 是长新冠区别于普通疲劳的标志性症状。在 PEM 期间强行硬撑可能会显著恶化病情。","breadcrumbs":"常见症状 » 其他常见症状","id":"12","title":"其他常见症状"},"13":{"body":"长新冠（Long COVID）可能影响任何曾感染过 COVID-19 的人，无论其年龄大小、既往健康状况或急性期病情严重程度如何。","breadcrumbs":"受影响人群 » 受影响人群","id":"13","title":"受影响人群"},"14":{"body":"据估计，约有 10–30% 的 COVID-19 感染者会出现某种形式的长新冠。 全球有数百万人受到影响。 未曾住院的感染者占长新冠病例的大多数。","breadcrumbs":"受影响人群 » 患病率","id":"14","title":"患病率"},"15":{"body":"研究确定了几个与更高风险相关的因素： 女性 高龄 急性期病情较重 患有基础疾病（如哮喘、糖尿病） 未接种 COVID-19 疫苗 研究表明，接种疫苗可以降低（但不能完全消除）患上长新冠的风险。","breadcrumbs":"受影响人群 » 风险因素","id":"15","title":"风险因素"},"16":{"body":"长新冠的影响程度不等，从轻微的不便到完全丧失生活能力。许多患者： 无法工作或工作能力下降 社交和家庭生活受到严重干扰 在获得准确诊断和适当护理方面面临挑战","breadcrumbs":"受影响人群 » 对日常生活的影响","id":"16","title":"对日常生活的影响"},"17":{"body":"对于长新冠（Long COVID）患者，尤其是那些经历过 劳累后不适 (PEM) 的人来说，“节奏调整”（Pacing）是最重要的自我管理策略之一。","breadcrumbs":"节奏调整与能量管理 » 节奏调整与能量管理","id":"17","title":"节奏调整与能量管理"},"18":{"body":"节奏调整意味着将活动量控制在现有的能量限制范围内，以避免触发 PEM。其目标是找到一种可持续的活动水平，而不会导致病情“崩溃”（Crashes）。","breadcrumbs":"节奏调整与能量管理 » 什么是节奏调整？","id":"18","title":"什么是节奏调整？"},"19":{"body":"可以将你每天的能量想象成一个固定的“信封”。体力、认知和情感活动都会消耗这个信封里的能量。节奏调整意味着： 保持在信封范围内，而不是挑战其边缘 在感到精疲力竭 之前 休息，而不是在之后 将活动分散到一整天中","breadcrumbs":"节奏调整与能量管理 » 能量信封 (The Energy Envelope)","id":"19","title":"能量信封 (The Energy Envelope)"},"2":{"body":"这是一个开放资源。如果您想贡献内容或提出改进建议，请访问我们的 GitHub 仓库 。","breadcrumbs":"引言 » 参与贡献 (Contributing)","id":"2","title":"参与贡献 (Contributing)"},"20":{"body":"许多人使用心率 (HR) 作为节奏调整的指南。保持在无氧阈值以下有助于预防 PEM。一个常用的估算公式为： $$节奏调整的最大心率 = (220 - 年龄) \\times 0.6$$ 可穿戴设备（如 Garmin、Apple Watch、Fitbit）可以帮助实时追踪心率。","breadcrumbs":"节奏调整与能量管理 » 心率监测","id":"20","title":"心率监测"},"21":{"body":"将任务分解为小块 ，并在期间安排休息 确定优先级 —— 识别哪些是真正需要做的，哪些可以稍后再说 认知休息 同样重要 —— 减少屏幕时间、噪音和多任务处理 记录活动/症状日记 —— 寻找个人的发病模式 避免“繁荣-崩溃”循环 —— 身体感觉较好的日子并不意味着可以过度活动","breadcrumbs":"节奏调整与能量管理 » 实用建议","id":"21","title":"实用建议"},"22":{"body":"来自职业疗法（Occupational Therapy）的一个有用框架： 优先化 (Prioritize) ：专注于最重要的事情 计划 (Plan) ：提前规划活动，避免最后一刻的仓促 节奏 (Pace) ：在每项活动中保持平稳的节奏","breadcrumbs":"节奏调整与能量管理 » 3P 原则","id":"22","title":"3P 原则"},"23":{"body":"目前尚无针对长新冠（Long COVID）的通用获批疗法。管理方式主要侧重于症状缓解。请与您的医疗服务提供者合作，根据您的具体症状制定方案。","breadcrumbs":"医疗方案 » 医疗方案","id":"23","title":"医疗方案"},"24":{"body":"症状领域 正在研究的处理方法 疲劳 / PEM 低剂量纳曲酮 (LDN)、节奏调整方案 自主神经失调 / POTS β-受体阻滞剂、增加盐分/液体摄入、压力服 脑雾 认知康复、抗组胺药物 睡眠 睡眠卫生、褪黑素、针对失眠的认知行为疗法 (CBT-I) 疼痛 抗炎药、物理治疗 抑郁/焦虑 选择性 5-羟色胺再摄取抑制剂 (SSRIs)、心理治疗 重要提示： 研究表明，分级运动疗法 (GET) 会加重患有 PEM（劳累后不适）者的病情。在制定任何运动计划前，请务必与医生慎重讨论。","breadcrumbs":"医疗方案 » 正在研究中的疗法","id":"24","title":"正在研究中的疗法"},"25":{"body":"您可能会从以下专科转诊中受益： 心内科 （针对 POTS、胸部症状） 神经内科 （针对脑雾、神经病变、头痛） 呼吸科 （针对呼吸症状） 风湿免疫科 （针对免疫/炎症问题） 精神科或心理科 （针对心理健康支持）","breadcrumbs":"医疗方案 » 专科转诊","id":"25","title":"专科转诊"},"26":{"body":"活跃的试验列于 ClinicalTrials.gov —— 搜索“Long COVID”或“PASC”即可找到正在招募的研究。","breadcrumbs":"医疗方案 » 临床试验","id":"26","title":"临床试验"},"27":{"body":"保留以下记录以便就诊时使用： 记录日期、严重程度和诱因的 症状日记 所有药物和膳食补充剂的清单 既往检查结果记录","breadcrumbs":"医疗方案 » 记录您的症状","id":"27","title":"记录您的症状"},"28":{"body":"患有一种往往被误解的慢性疾病，会给心理和情感带来巨大负担。关注心理健康是长新冠（Long COVID）管理中不可或缺的一部分。","breadcrumbs":"心理健康 » 心理健康","id":"28","title":"心理健康"},"29":{"body":"抑郁 —— 源于疾病负担、功能丧失以及对未来的不确定感。 焦虑 —— 担心症状、康复进度以及生活前景。 哀伤 —— 怀念患病前的自己以及那些被迫放弃的活动。 医疗“煤气灯”效应 (Medical Gaslighting) —— 被医护人员轻视或不信任。 孤独感 —— 由于社交能力受限而产生的隔阂。","breadcrumbs":"心理健康 » 常见的心理健康挑战","id":"29","title":"常见的心理健康挑战"},"3":{"body":"长新冠（Long COVID）是指在 COVID-19 急性感染后持续四周或更长时间的一系列广泛健康问题。无论初始病情的严重程度如何，它都可能影响感染者——包括轻症或无症状感染者。","breadcrumbs":"什么是长新冠？ » 什么是长新冠？","id":"3","title":"什么是长新冠？"},"30":{"body":"与您的全科医生或首诊医生讨论您的心理健康症状。 请求转诊给在慢性病领域有经验的治疗师或心理学家。 同伴支持小组（在线或当地）可以提供理解和实用的建议。","breadcrumbs":"心理健康 » 寻求支持","id":"30","title":"寻求支持"},"31":{"body":"认可自己的经历 —— 即使化验结果正常，长新冠也是真实存在的。 设定界限 —— 拒绝那些可能导致病情崩溃（Crash）的活动是可以接受的。 与他人联系 —— 参与在线长新冠社区可以减轻孤独感。 庆祝每一个微小的胜利 —— 康复过程通常不是线性的，任何进步都值得肯定。","breadcrumbs":"心理健康 » 自我照顾策略","id":"31","title":"自我照顾策略"},"32":{"body":"认知行为疗法（CBT）可以帮助患者学习应对慢性病的策略。然而，如果 CBT 试图质疑患者的疾病感受或强行提高活动水平，可能并不适合长新冠患者。建议寻找熟悉慢性疲劳病症的治疗师。","breadcrumbs":"心理健康 » 关于认知行为疗法 (CBT) 的说明","id":"32","title":"关于认知行为疗法 (CBT) 的说明"},"33":{"body":"精选的长新冠（Long COVID）关键研究及正在进行的科研项目。","breadcrumbs":"科研与研究 » 科研与研究","id":"33","title":"科研与研究"},"34":{"body":"RECOVER 计划 (NIH) —— 美国针对长新冠开展的大型观察性研究和临床试验项目。 英国生物样本库 (UK Biobank) 长新冠研究 —— 关于患病率和风险因素的人群级数据。 Ziyad Al-Aly 研究项目 (VA/NEJM) —— 对长新冠后果的综合分析。","breadcrumbs":"科研与研究 » 里程碑式研究","id":"34","title":"里程碑式研究"},"35":{"body":"长新冠会影响多个器官系统，且可能在轻症感染后发生。 接种疫苗可降低但不能完全消除患长新冠的风险。 在长新冠患者中已发现明显的生物学异常（如微血栓、T 细胞失调、病毒持久性）。 ME/CFS（肌痛性脑脊髓炎/慢性疲劳综合征）与长新冠在生物学上存在显著重叠。","breadcrumbs":"科研与研究 » 关键发现","id":"35","title":"关键发现"},"36":{"body":"medRxiv —— 预印本（尚未经过同行评审） The Lancet (柳叶刀) Nature Medicine (自然医学) NEJM (新英格兰医学杂志)","breadcrumbs":"科研与研究 » 预印本平台与期刊","id":"36","title":"预印本平台与期刊"},"37":{"body":"可访问 ClinicalTrials.gov 搜索正在招募志愿者的长新冠研究。","breadcrumbs":"科研与研究 » 正在进行的试验","id":"37","title":"正在进行的试验"},"38":{"body":"你并不孤单。目前有许多由长新冠（Long COVID）患者、倡导者和研究人员组成的社区正在共同努力。","breadcrumbs":"支持团体 » 支持团体","id":"38","title":"支持团体"},"39":{"body":"Long COVID Support —— 针对患者和护理人员的大型 Facebook 社群。 Body Politic —— 患者主导的新冠肺炎支持团体和研究协作体。 Long COVID Alliance —— 由患者组织和研究机构组成的联盟。 ME/CFS 与长新冠 Reddit 讨论版 —— Reddit 上的 r/covidlonghaulers 板块。","breadcrumbs":"支持团体 » 在线社区","id":"39","title":"在线社区"},"4":{"body":"症状在初始感染后持续数周、数月甚至更久 可能同时影响多个器官系统 症状可能反复发作、缓解或随时间波动 无法通过其他替代诊断来解释","breadcrumbs":"什么是长新冠？ » 主要特征","id":"4","title":"主要特征"},"40":{"body":"患者主导的研究协作组织 (Patient-Led Research Collaborative) —— 由研究长新冠的患者研究员组成。 长新冠联盟 (Long COVID Alliance) —— 总部位于美国的倡导与研究联盟。 Long Covid SOS (英国) —— 致力于提高公众认知的倡导团体。","breadcrumbs":"支持团体 » 患者组织","id":"40","title":"患者组织"},"41":{"body":"咨询您的医生，了解当地是否有长新冠门诊或支持小组。 咨询当地医院 —— 许多医院已经建立了专门的长新冠服务部门。 鉴于症状的重叠，当地的 ME/CFS（慢性疲劳综合征）团体通常也欢迎长新冠患者加入。","breadcrumbs":"支持团体 » 寻找当地支持","id":"41","title":"寻找当地支持"},"42":{"body":"精选的外部资源列表。","breadcrumbs":"常用链接 » 常用链接","id":"42","title":"常用链接"},"43":{"body":"美国疾控中心 (CDC) — 新冠后状况 世界卫生组织 (WHO) — 新冠后状态 美国国立卫生研究院 (NIH) RECOVER 计划","breadcrumbs":"常用链接 » 官方卫生组织","id":"43","title":"官方卫生组织"},"44":{"body":"患者主导的研究协作组织 (Patient-Led Research Collaborative) 长新冠联盟 (Long COVID Alliance) 国际自主神经功能障碍组织 — POTS 资源","breadcrumbs":"常用链接 » 患者资源","id":"44","title":"患者资源"},"45":{"body":"Visible App —— 针对劳累后不适 (PEM) 的节奏管理和心率监测 Bearable —— 症状与健康追踪应用 ClinicalTrials.gov —— 查找正在进行的临床试验","breadcrumbs":"常用链接 » 工具与应用","id":"45","title":"工具与应用"},"46":{"body":"长新冠：主要发现、机制与建议 (Nature Reviews, 2023)","breadcrumbs":"常用链接 » 延伸阅读","id":"46","title":"延伸阅读"},"5":{"body":"世界卫生组织 (WHO) 将“新冠后状况”定义为：通常发生在 COVID-19 发病后的 3 个月内，症状持续至少 2 个月，且无法由其他诊断解释。 美国疾病控制与预防中心 (CDC) 使用“新冠后状况”（Post-COVID Conditions）一词来统称感染四周或更长时间后出现的各种健康后果。","breadcrumbs":"什么是长新冠？ » 官方定义","id":"5","title":"官方定义"},"6":{"body":"研究人员正在调查几种潜在病因，包括： 病毒持久性或病毒库 免疫失调和慢性炎症 微生物群失调 潜伏病毒（如 EBV）的重新激活 自身抗体的形成 微血栓和血管损伤","breadcrumbs":"什么是长新冠？ » 可能的发病机制","id":"6","title":"可能的发病机制"},"7":{"body":"据报告，长新冠（Long COVID）可能表现出超过 200 种症状。其中最常见的包括：","breadcrumbs":"常见症状 » 常见症状","id":"7","title":"常见症状"},"8":{"body":"脑雾 （思维、集中注意力或记忆困难） 头痛 睡眠障碍 头晕或眩晕","breadcrumbs":"常见症状 » 神经系统与认知","id":"8","title":"神经系统与认知"},"9":{"body":"心悸或心跳加速 体位性心动过速综合征 (POTS) 胸痛或胸闷","breadcrumbs":"常见症状 » 心血管与自主神经","id":"9","title":"心血管与自主神经"}},"length":47,"save":true},"fields":["title","body","breadcrumbs"],"index":{"body":{"root":{"0":{".":{"6":{"df":1,"docs":{"20":{"tf":1.0}}},"df":